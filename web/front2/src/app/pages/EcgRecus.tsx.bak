import { useState } from 'react';
import { MedecinLayout } from '../components/MedecinLayout';
import { Badge } from '../components/ui/badge';
import { Button } from '../components/ui/button';
import { Input } from '../components/ui/input';
import {
  Activity,
  Search,
  Download,
  Eye,
  Clock,
  CheckCircle,
  Filter,
  Calendar,
  FileText,
  SortAsc,
  Inbox,
} from 'lucide-react';
import { Link } from 'react-router-dom';

type StatutEcg = 'En attente' | 'En cours' | 'Traité';

interface EcgRecu {
  id: number;
  patientNom: string;
  patientAge: number;
  patientId: number;
  dateEnvoi: string;
  heureEnvoi: string;
  fichier: string;
  taille: string;
  statut: StatutEcg;
}

const ecgsRecus: EcgRecu[] = [
  { id: 1, patientNom: 'Marie Dubois',    patientAge: 62, patientId: 1, dateEnvoi: '02/04/2024', heureEnvoi: '14:30', fichier: 'ecg_dubois_02042024.pdf',    taille: '2.4 Mo', statut: 'En attente' },
  { id: 2, patientNom: 'Robert Petit',    patientAge: 67, patientId: 6, dateEnvoi: '02/04/2024', heureEnvoi: '11:05', fichier: 'ecg_petit_02042024.pdf',     taille: '1.8 Mo', statut: 'En attente' },
  { id: 3, patientNom: 'Pierre Lefebvre', patientAge: 71, patientId: 4, dateEnvoi: '02/04/2024', heureEnvoi: '09:20', fichier: 'ecg_lefebvre_02042024.pdf',  taille: '2.1 Mo', statut: 'En attente' },
  { id: 4, patientNom: 'Jean Martin',     patientAge: 55, patientId: 2, dateEnvoi: '01/04/2024', heureEnvoi: '16:45', fichier: 'ecg_martin_01042024.pdf',    taille: '1.6 Mo', statut: 'En attente' },
  { id: 5, patientNom: 'Sophie Bernard',  patientAge: 48, patientId: 3, dateEnvoi: '01/04/2024', heureEnvoi: '14:00', fichier: 'ecg_bernard_01042024.pdf',   taille: '1.9 Mo', statut: 'En attente' },
  { id: 6, patientNom: 'Anne Rousseau',   patientAge: 59, patientId: 5, dateEnvoi: '01/04/2024', heureEnvoi: '10:30', fichier: 'ecg_rousseau_01042024.pdf',  taille: '2.0 Mo', statut: 'En attente' },
  { id: 7, patientNom: 'Marie Dubois',    patientAge: 62, patientId: 1, dateEnvoi: '31/03/2024', heureEnvoi: '08:55', fichier: 'ecg_dubois_31032024.pdf',    taille: '2.2 Mo', statut: 'En attente' },
];

const statutConfig: Record<StatutEcg, { bg: string; color: string; icon: React.ReactNode }> = {
  'En attente': { bg: '#FEF3C7', color: '#854F0B', icon: <Clock className="w-3 h-3" /> },
  'En cours':   { bg: '#EEF2FF', color: '#534AB7', icon: <Activity className="w-3 h-3" /> },
  'Traité':     { bg: '#E8F5F2', color: '#0F6E56', icon: <CheckCircle className="w-3 h-3" /> },
};

const avatarColors     = ['#EEF2FF', '#E1F5EE', '#FCEBEB', '#FEF3C7', '#E6F1FB', '#FBEAF0'];
const avatarTextColors = ['#534AB7', '#0F6E56', '#A32D2D', '#854F0B', '#185FA5', '#993556'];

function getInitials(nom: string) {
  const parts = nom.trim().split(' ');
  return parts.length >= 2 ? `${parts[0][0]}${parts[1][0]}`.toUpperCase() : nom.slice(0, 2).toUpperCase();
}

type FiltreStatut = 'tous' | StatutEcg;

export default function EcgRecus() {
  const [search, setSearch]             = useState('');
  const [filtreStatut, setFiltreStatut] = useState<FiltreStatut>('tous');
  const [triDate, setTriDate]           = useState<'desc' | 'asc'>('desc');

  const enAttente = ecgsRecus.filter((e) => e.statut === 'En attente').length;
  const enCours   = ecgsRecus.filter((e) => e.statut === 'En cours').length;
  const traites   = ecgsRecus.filter((e) => e.statut === 'Traité').length;

  const filtered = ecgsRecus
    .filter((e) => {
      const matchSearch  = e.patientNom.toLowerCase().includes(search.toLowerCase());
      const matchStatut  = filtreStatut === 'tous' || e.statut === filtreStatut;
      return matchSearch && matchStatut;
    })
    .sort((a, b) => {
      const da = a.dateEnvoi.split('/').reverse().join('') + a.heureEnvoi;
      const db = b.dateEnvoi.split('/').reverse().join('') + b.heureEnvoi;
      return triDate === 'desc' ? db.localeCompare(da) : da.localeCompare(db);
    });

  return (
    <MedecinLayout>
      <div className="p-8 space-y-6">

        {/* ── Header ── */}
        <div className="flex items-center gap-4">
          <div
            className="w-12 h-12 rounded-2xl flex items-center justify-center flex-shrink-0"
            style={{ background: '#EEF2FF', border: '1px solid #C7D2FE' }}
          >
            <Inbox className="w-6 h-6" style={{ color: '#534AB7' }} />
          </div>
          <div>
            <h1
              className="text-3xl font-bold leading-none mb-1"
              style={{ fontFamily: 'var(--font-family-heading)', color: 'var(--text-primary)' }}
            >
              ECG Reçus
            </h1>
            <p style={{ color: 'var(--text-secondary)', fontSize: '13px' }}>
              Boîte de réception · {ecgsRecus.length} fichiers au total
            </p>
          </div>
        </div>

        {/* ── 3 carrés stats ── */}
        

        {/* ── Barre de filtres ── */}
        <div
          className="flex items-center gap-3 flex-wrap px-4 py-3 rounded-2xl"
          style={{ background: 'var(--surface)', border: '1px solid var(--border-color)' }}
        >
          <div className="relative" style={{ minWidth: '180px', flex: 1, maxWidth: '280px' }}>
            <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5" style={{ color: 'var(--text-secondary)' }} />
            <Input
              placeholder="Rechercher un patient..."
              value={search}
              onChange={(e) => setSearch(e.target.value)}
              className="pl-8 h-8"
              style={{ borderRadius: '8px', fontSize: '13px' }}
            />
          </div>

          <div className="w-px h-5" style={{ background: 'var(--border-color)' }} />

          <div className="flex items-center gap-1.5">
            <Filter className="w-3.5 h-3.5" style={{ color: 'var(--text-secondary)' }} />
            {(['tous', 'En attente', 'En cours', 'Traité'] as FiltreStatut[]).map((f) => (
              <button
                key={f}
                onClick={() => setFiltreStatut(f)}
                style={{
                  padding: '4px 12px',
                  borderRadius: '20px',
                  fontSize: '12px',
                  fontWeight: filtreStatut === f ? 500 : 400,
                  border: filtreStatut === f ? '1.5px solid var(--primary)' : '1px solid var(--border-color)',
                  background: filtreStatut === f ? 'var(--primary)' : 'transparent',
                  color: filtreStatut === f ? 'white' : 'var(--text-secondary)',
                  cursor: 'pointer',
                  transition: 'all 0.15s',
                  whiteSpace: 'nowrap' as const,
                }}
              >
                {f === 'tous' ? 'Tous' : f}
              </button>
            ))}
          </div>

          <button
            onClick={() => setTriDate((t) => (t === 'desc' ? 'asc' : 'desc'))}
            style={{
              padding: '4px 12px',
              borderRadius: '20px',
              fontSize: '12px',
              border: '1px solid var(--border-color)',
              background: 'transparent',
              color: 'var(--text-secondary)',
              cursor: 'pointer',
              display: 'flex',
              alignItems: 'center',
              gap: '4px',
              marginLeft: 'auto',
            }}
          >
            <SortAsc className="w-3 h-3" />
            {triDate === 'desc' ? 'Plus récents' : 'Plus anciens'}
          </button>
        </div>

        {/* ── Table ECGs ── */}
        <div
          style={{
            borderRadius: '16px',
            border: '1px solid var(--border-color)',
            background: 'var(--surface)',
            overflow: 'hidden',
          }}
        >
          {/* En-tête */}
          <div
            style={{
              display: 'grid',
              gridTemplateColumns: '2fr 1.1fr 0.9fr auto',
              padding: '10px 20px',
              background: 'var(--background)',
              borderBottom: '1px solid var(--border-color)',
            }}
          >
            {['Patient / Fichier ECG', 'Date de réception', 'Statut', 'Actions'].map((h) => (
              <span
                key={h}
                style={{
                  fontSize: '11px',
                  fontWeight: 500,
                  color: 'var(--text-secondary)',
                  textTransform: 'uppercase' as const,
                  letterSpacing: '0.06em',
                }}
              >
                {h}
              </span>
            ))}
          </div>

          {/* Lignes */}
          {filtered.length === 0 ? (
            <div className="text-center py-14" style={{ color: 'var(--text-secondary)' }}>
              <FileText className="w-8 h-8 mx-auto mb-2 opacity-25" />
              <p className="text-sm">Aucun ECG trouvé</p>
            </div>
          ) : (
            filtered.map((ecg, idx) => {
              const statut    = statutConfig[ecg.statut];
              const initials  = getInitials(ecg.patientNom);
              const avatarBg  = avatarColors[ecg.patientId % avatarColors.length];
              const avatarTxt = avatarTextColors[ecg.patientId % avatarTextColors.length];
              const isLast    = idx === filtered.length - 1;

              return (
                <div
                  key={ecg.id}
                  style={{
                    display: 'grid',
                    gridTemplateColumns: '2fr 1.1fr 0.9fr auto',
                    alignItems: 'center',
                    padding: '14px 20px',
                    borderBottom: isLast ? 'none' : '1px solid var(--border-color)',
                    background: 'transparent',
                    transition: 'background 0.12s',
                    cursor: 'default',
                  }}
                  onMouseEnter={(e) => (e.currentTarget.style.background = 'var(--background)')}
                  onMouseLeave={(e) => (e.currentTarget.style.background = 'transparent')}
                >
                  {/* Col 1 — Patient + fichier */}
                  <div className="flex items-center gap-3 min-w-0 pr-4">
                    <div
                      style={{
                        width: '3px',
                        height: '38px',
                        borderRadius: '2px',
                        background: 'var(--border-color)',
                        flexShrink: 0,
                      }}
                    />
                    <div
                      className="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-medium"
                      style={{ background: avatarBg, color: avatarTxt }}
                    >
                      {initials}
                    </div>
                    <div className="min-w-0">
                      <div className="flex items-center gap-1.5 mb-0.5 flex-wrap">
                        <span className="text-sm font-medium" style={{ color: 'var(--text-primary)' }}>
                          {ecg.patientNom}
                        </span>
                        <span className="text-xs" style={{ color: 'var(--text-secondary)' }}>
                          {ecg.patientAge} ans
                        </span>
                      </div>
                      <div className="flex items-center gap-1.5">
                        <FileText className="w-3 h-3 flex-shrink-0" style={{ color: 'var(--text-secondary)' }} />
                        <span className="text-xs truncate" style={{ color: 'var(--text-secondary)' }}>
                          {ecg.fichier}
                        </span>
                        <span className="text-xs flex-shrink-0" style={{ color: 'var(--text-secondary)' }}>
                          · {ecg.taille}
                        </span>
                      </div>
                    </div>
                  </div>

                  {/* Col 2 — Date */}
                  <div>
                    <div className="flex items-center gap-1.5 mb-0.5">
                      <Calendar className="w-3 h-3" style={{ color: 'var(--text-secondary)' }} />
                      <span className="text-sm font-medium" style={{ color: 'var(--text-primary)' }}>
                        {ecg.dateEnvoi}
                      </span>
                    </div>
                    <div className="flex items-center gap-1.5 pl-0.5" style={{ paddingLeft: '1.1rem' }}>
                      <Clock className="w-3 h-3" style={{ color: 'var(--text-secondary)' }} />
                      <span className="text-xs" style={{ color: 'var(--text-secondary)' }}>
                        {ecg.heureEnvoi}
                      </span>
                    </div>
                  </div>

                  {/* Col 3 — Statut */}
                  <div>
                    <Badge
                      style={{
                        background: statut.bg,
                        color: statut.color,
                        border: 'none',
                        borderRadius: '8px',
                        fontSize: '11px',
                        padding: '4px 10px',
                        display: 'inline-flex',
                        alignItems: 'center',
                        gap: '4px',
                      }}
                    >
                      {statut.icon}
                      {ecg.statut}
                    </Badge>
                  </div>

                  {/* Col 4 — Actions */}
                  <div className="flex items-center gap-2">
                    <Button
                      size="sm"
                      variant="outline"
                      style={{
                        borderRadius: '8px',
                        fontSize: '12px',
                        padding: '0 10px',
                        height: '32px',
                        borderColor: 'var(--border-color)',
                      }}
                      onClick={() => {
                        const a = document.createElement('a');
                        a.href = `/ecgs/${ecg.fichier}`;
                        a.download = ecg.fichier;
                        a.click();
                      }}
                    >
                      <Download className="w-3.5 h-3.5 mr-1" />
                      Télécharger
                    </Button>
                    <Link to={`/analyse-ecg/${ecg.id}`}>
                      <Button
                        size="sm"
                        style={{
                          borderRadius: '8px',
                          fontSize: '12px',
                          padding: '0 12px',
                          height: '32px',
                          background: 'var(--primary)',
                          color: 'white',
                        }}
                      >
                        <Eye className="w-3.5 h-3.5 mr-1" />
                        Analyser
                      </Button>
                    </Link>
                  </div>
                </div>
              );
            })
          )}
        </div>

      </div>
    </MedecinLayout>
  );
}